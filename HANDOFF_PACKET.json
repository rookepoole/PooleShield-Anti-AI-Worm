{
  "tool": "PooleShield",
  "version": "5.3.0",
  "release_type": "continuity_handoff",
  "last_updated": "2026-06-28",
  "mission": "Privacy-first, defensive, non-executing second-opinion scanner for suspicious files, archives, scripts, AI-agent logs, exported data bundles, and local workflow artifacts.",
  "current_release": "v5.3",
  "current_milestone": "Safe Corpus + Benchmark Harness",
  "safety_boundary": {
    "allowed": [
      "read local files for static scanning",
      "write metadata/report outputs",
      "apply human review ledgers",
      "apply local trusted baselines as ALLOW_LOG",
      "write local metadata-only scan history",
      "load metadata-only scan results for UI review",
      "load metadata-only trusted baseline entries for UI review",
      "compare two local baseline JSON files by SHA256",
      "load and validate local file-AV rule packs",
      "write explicit operator-requested rule-pack JSON copies",
      "bundle privacy-safe results",
      "write metadata-only release manifests",
      "write release-notes drafts",
      "hash release artifacts without copying/executing them"
    ],
    "not_allowed": [
      "execute scanned files",
      "delete scanned files",
      "automatic quarantine",
      "kill processes",
      "install hooks or drivers",
      "upload raw scanned contents by default",
      "silently trust files from rule packs",
      "publish private Poole Math / Poole Manifold / Poole Defect Calculus IP",
      "commit installer executables or portable build folders",
      "commit generated release manifest responses or verification ZIPs"
    ]
  },
